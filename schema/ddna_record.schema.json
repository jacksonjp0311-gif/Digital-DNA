{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jacksonjp0311-gif/Digital-DNA/schema/ddna_record.schema.json",
  "title": "Digital-DNA Scan Record",
  "type": "object",
  "required": [
    "retention",
    "drift",
    "drift_raw",
    "drift_topology",
    "drift_dependency",
    "weights",
    "stability",
    "bio_signature",
    "timestamp"
  ],
  "properties": {
    "retention": { "type": "number", "minimum": 0 },
    "drift": { "type": "number", "minimum": 0, "maximum": 1 },
    "drift_raw": { "type": "number", "minimum": 0 },
    "drift_topology": { "type": "number", "minimum": 0, "maximum": 1 },
    "drift_dependency": { "type": "number", "minimum": 0, "maximum": 1 },
    "weights": {
      "type": "object",
      "required": ["topology", "dependency"],
      "properties": {
        "topology": { "type": "number", "minimum": 0 },
        "dependency": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "stability": { "type": "number" },
    "bio_signature": {
      "type": "object",
      "required": [
        "alphabet",
        "sequence_length",
        "role_counts",
        "gc_like_content",
        "k",
        "distinct_kmers",
        "kmer_entropy",
        "sequence_entropy",
        "normalized_sequence_entropy",
        "contig_count",
        "n50",
        "motifs",
        "fold_balance"
      ],
      "properties": {
        "alphabet": { "type": "string" },
        "sequence_length": { "type": "integer", "minimum": 0 },
        "role_counts": { "type": "object" },
        "gc_like_content": { "type": "number", "minimum": 0, "maximum": 1 },
        "k": { "type": "integer", "minimum": 1 },
        "distinct_kmers": { "type": "integer", "minimum": 0 },
        "kmer_entropy": { "type": "number", "minimum": 0 },
        "sequence_entropy": { "type": "number", "minimum": 0 },
        "normalized_sequence_entropy": { "type": "number", "minimum": 0, "maximum": 1 },
        "contig_count": { "type": "integer", "minimum": 0 },
        "n50": { "type": "integer", "minimum": 0 },
        "motifs": { "type": "object" },
        "fold_balance": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "timestamp": { "type": "string" },
    "gate": {
      "type": "object",
      "required": ["passed", "violations", "policy"],
      "properties": {
        "passed": { "type": "boolean" },
        "violations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy": {
          "type": "object",
          "required": [
            "min_stability",
            "max_drift",
            "max_topology_drift",
            "max_dependency_drift",
            "require_retention"
          ],
          "properties": {
            "min_stability": { "type": "number", "minimum": 0 },
            "max_drift": { "type": "number", "minimum": 0 },
            "max_topology_drift": { "type": "number", "minimum": 0 },
            "max_dependency_drift": { "type": "number", "minimum": 0 },
            "require_retention": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
